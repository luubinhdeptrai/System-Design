# Server
PORT=3000

# Database — PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/saas_auth_demo

# Better Auth
# Must be at least 32 characters. Rotating this invalidates all active sessions.
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret-now

# Public URL of this server. Used by Better Auth to build callback URLs
# (OAuth redirects, magic link URLs in emails).
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated list of frontend origins allowed to send cookies.
# Better Auth validates the Origin header against this list (CSRF protection).
TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000
